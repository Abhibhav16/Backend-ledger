# MongoDB Configuration
# Note: For transactions to work, MongoDB must run as a Replica Set.
# Local Docker setup uses: mongodb://db:27017/ledger?replicaSet=rs0
MONGO_URI=mongodb://localhost:27017/ledger?replicaSet=rs0

# JWT Auth Secret Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Nodemailer / Gmail OAuth2 Configuration
EMAIL_USER=your-email@gmail.com
CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-google-oauth-client-secret
REFRESH_TOKEN=your-google-oauth-refresh-token

# Logging Configuration
LOG_LEVEL=info
NODE_ENV=development
PORT=3000
